{
    "name": "Thoughty Dev Container",
    "dockerComposeFile": "docker-compose.yml",
    "service": "app",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "postCreateCommand": "npm install && cd thoughty-server && npm install && cd ../thoughty-web && npm install",
    "customizations": {
        "vscode": {
            "extensions": [
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode",
                "bradlc.vscode-tailwindcss",
                "Orta.vscode-jest",
                "ms-playwright.playwright",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "GitHub.vscode-pull-request-github"
            ],
            "settings": {
                "editor.formatOnSave": true,
                "editor.defaultFormatter": "esbenp.prettier-vscode",
                "editor.codeActionsOnSave": {
                    "source.fixAll.eslint": "explicit"
                },
                "typescript.tsdk": "thoughty-web/node_modules/typescript/lib"
            }
        }
    },
    "forwardPorts": [
        3001,
        5173,
        5432,
        9000,
        9001
    ],
    "portsAttributes": {
        "3001": { "label": "Backend API" },
        "5173": { "label": "Frontend (Vite)" },
        "5432": { "label": "PostgreSQL" },
        "9000": { "label": "MinIO API" },
        "9001": { "label": "MinIO Console" }
    }
}
