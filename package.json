{
  "name": "thoughty",
  "version": "1.0.0",
  "description": "A modern journal application",
  "license": "MIT",
  "private": true,
  "scripts": {
    "api:sync": "npm --prefix thoughty-server run openapi:export && npm --prefix thoughty-web run api:types",
    "migrate": "cd thoughty-server && npm run db:migrate",
    "seed": "cd thoughty-server && npm run db:seed",
    "check-db": "cd thoughty-server && npm run db:check",
    "nuke-db": "cd thoughty-server && npm run db:nuke",
    "kill": "cd thoughty-server && npm run kill-node",
    "coverage": "cd thoughty-server && npm run coverage-report"
  }
}


