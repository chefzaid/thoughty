# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=journal
POSTGRES_POOL_MAX=10
POSTGRES_POOL_IDLE_TIMEOUT_MS=30000
POSTGRES_POOL_CONNECTION_TIMEOUT_MS=5000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
REFRESH_SECRET=refresh-secret-change-in-production
REFRESH_EXPIRES_IN=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Thoughty <your-email@gmail.com>"

# Environment
NODE_ENV=development
PORT=3001

# S3 / Object Storage
# Defaults below work with local MinIO from docker-compose (no .env needed for local dev)
# For production, use AWS S3 or any S3-compatible provider — see README for details
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=thoughty-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# Config encryption (for sensitive settings)
CONFIG_ENCRYPTION_SECRET=your-encryption-secret-change-in-production

# AI (OpenRouter)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_TAG_MODEL=openai/gpt-4o-mini

# Cloud Sync OAuth (optional — required only if you want cloud sync)
# Google Drive: https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
# OneDrive: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
ONEDRIVE_CLIENT_ID=
ONEDRIVE_CLIENT_SECRET=
# Dropbox: https://www.dropbox.com/developers/apps
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
